# Sky Player — Editor settings
# Pin formatting once at the editor level so no one wastes a commit on CR/LF drift.

root = true

[*]
charset        = utf-8
end_of_line    = lf
indent_style   = space
trim_trailing_whitespace = true
insert_final_newline    = true

[*.{py,pyi}]
indent_size    = 4
max_line_length = 120

[*.{yml,yaml,toml,json}]
indent_size    = 2

[*.bat]
end_of_line    = crlf

[*.md]
trim_trailing_whitespace = false
