# Sky Auto Player — local uv overrides
# Copy this file to `.env` and adjust if needed.
# `.env` is gitignored; do not commit it.

# Pin uv's cache inside the project so cache and target share one volume.
# Cross-volume hardlinks (C: <-> V:) force deep-copy on Windows; this avoids
# the "Failed to hardlink files" warning emitted by `uv sync`.
UV_CACHE_DIR=.uv-cache

# Prefer hardlink, fall back to copy automatically if cross-volume is unavoidable.
UV_LINK_MODE=hardlink

# Force stdio to UTF-8 for intercepted/captured streams (e.g. `subprocess.run(..., capture_output=True)`
# in `build_app.run_smoke_test`). NOTE: this does NOT affect the main script's own console print
# on Windows — that is bound to `GetConsoleOutputCP` and needs `chcp 65001` (or a `sys.stdout.reconfigure`
# call inside `build_app.main`). uv forwards this var into the child interpreter.
PYTHONIOENCODING=utf-8
